# Copy to .env and fill in your values before running docker-compose

# Firefly III
FIREFLY_URL=http://localhost:8080
FIREFLY_TOKEN=

# LLM endpoint (OpenAI-compatible, e.g. Ollama)
LLM_URL=http://localhost:11434/v1
LLM_MODEL=gemma3:4b

# Telegram bot for batch summaries
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# API key for the iOS Shortcut (anything secret)
INGEST_API_KEY=change-me-to-a-long-random-string
